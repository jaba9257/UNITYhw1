# Standard Unity gitignore 
# =========================

# [Autogenerated files]
# =====================
/Library/
/Temp/
/obj/
/Build/
/Builds/
/Logs/
/UserSettings/
/UserLayouts.log

# [Visual Studio]
# ===============
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# [VS Code]
# =========
.vscode/
*.code-workspace

# [Rider]
# =======
.idea/
*.sln.iml

# [Mac]
# =====
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# [Cache]
# =======
*.db
*.db-journal

# [Crash reports]
# ===============
crashlytics-*.log

# [Unity cache]
# =============
/externaldependencymanager
/obj/
/Build/
/build/
/cloudbuild/
*/**/StreamingAssets/AAE*
*/**/StreamingAssets/AssetBundles.meta

# [VCS generated files]
# =====================
*.orig
*.meta.txt
*.unitypackage

# [Gradle]
# ========
gradle-app.setting
!gradle-wrapper.jar
.gradle
**/gradle/
**/gradlew
**/gradlew.bat
**/gradle-wrapper.jar
**/local.properties

# [Android]
# =========
*.apk
*.aab
*.keystore
*.jks

# [iOS]
# ====
*.xcodeproj/
*.xcworkspace/
*.pbxproj
*.plist
*.xcscheme
*.xcsettings
*.xcconfig
*.entitlements
*.bundle
*.dSYM/
*.framework/
*.app/
*.xcarchive/
# Visual Studio specific
.vs/
*.csproj.user
*.csproj.DotSettings

# [Specific to your project]
# ==========================
# Если хотите игнорировать конкретные папки
# /Assets/StreamingAssets/secret/
# /Assets/Plugins/thirdparty/
#Гит игнор нейросгенерирован